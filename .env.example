# Reddit API credentials (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=HyeTasion/1.0 by your_reddit_username

# Target subreddit to post to
# Use ArmeniansGlobal for the global Armenian diaspora community
TARGET_SUBREDDIT=ArmeniansGlobal

# Subreddits to analyze for engagement patterns (comma-separated)
ANALYSIS_SUBREDDITS=ArmeniansGlobal,armenia,hayastan,armenianhistory,history,worldnews

# App settings
SECRET_KEY=change_this_to_a_random_secret_key
DATABASE_URL=sqlite:///./hye_tasion.db
LOG_LEVEL=INFO

# Scraping settings (minutes between scrape cycles)
SCRAPE_INTERVAL_MINUTES=60

# Optional: OpenAI API for AI-assisted post generation
# OPENAI_API_KEY=your_openai_key_here
